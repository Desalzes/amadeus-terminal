{
  manifest_version: "0.1.0",

  // Config the deployer supplies per assessment. API keys are secrets; all optional
  // (the agent defaults the model and runs key-less for the agent-card/conformance path).
  config_schema: {
    type: "object",
    properties: {
      anthropic_api_key: { type: "string", secret: true },
      openai_api_key: { type: "string", secret: true },
      model: { type: "string" },          // e.g. anthropic/claude-opus-4-8 | openai/gpt-5.5
      critic_model: { type: "string" },   // optional adversarial-critic model; "" => same as model
    },
    required: [],
    additionalProperties: true,
  },

  program: {
    image: "ghcr.io/desalzes/amadeus-terminal:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",
    env: {
      ANTHROPIC_API_KEY: {
        when: "config.anthropic_api_key",
        value: "${config.anthropic_api_key}",
      },
      OPENAI_API_KEY: {
        when: "config.openai_api_key",
        value: "${config.openai_api_key}",
      },
      AMADEUS_MODEL: {
        when: "config.model",
        value: "${config.model}",
      },
      AMADEUS_CRITIC_MODEL: {
        when: "config.critic_model",
        value: "${config.critic_model}",
      },
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 }, // matches the entrypoint + Dockerfile EXPOSE
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
